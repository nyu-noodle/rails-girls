<p style="color: green"><%= notice %></p>

<% content_for :title, "Ideas" %>

<h1>Ideas</h1>



<div class="card">
  <div class="card-body">
    <% @ideas.each do |idea| %>
      <%= render idea %>
      <p>
        <%= link_to "詳細を見る", idea, class: "btn btn-outline-secondary btn-sm" %>
      </p>
    <% end %>
  </div>
</div>

<%= link_to "新規登録", new_idea_path, class: "btn btn-primary mt-2" %>
